/data/*.pdf
/data/*.jpeg
/data/*.jpg
/data/*.png
/data/*.webp

# Generated caches (rebuild with npm run process-images)
/storage/chunks
/storage/uploads
/storage/ocr
/storage/extracted
/storage/extracted/spsc-pdf-pages

# Keep for deploy: storage/mcqs.json, storage/super.txt, storage/structured, storage/pdf-batches
